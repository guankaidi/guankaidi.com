---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostList from "../components/PostList.astro";
import { getAllTags, normalizePosts } from "../lib/posts";

const posts = normalizePosts(import.meta.glob("./blog/*.md", { eager: true }));
const latestPosts = posts.slice(0, 4);
const tags = getAllTags(posts);
---

<BaseLayout
  title="关凯迪"
  description="关凯迪的个人站，围绕 AI 内容系统、个人 IP 写作、内容流程搭建和语音输入工具探索。"
>
  <section class="home-grid" aria-labelledby="home-title">
    <div class="home-copy">
      <p class="eyebrow">guankaidi.com / personal content system</p>
      <h1 id="home-title">把经验整理成持续可见的内容资产</h1>
      <p class="hero-name">关凯迪</p>
      <p class="home-title-note">AI 内容系统搭建 / 个人 IP 内容 / 语音输入工具探索</p>
      <p class="home-intro">
        我关注的是一件具体的事：把一个人的产品、用户、素材、写作偏好和交付经验，整理成一套能反复运行的内容系统。
      </p>
      <ul class="profile-points" aria-label="关凯迪关注的问题">
        <li>有交付、有判断、有方法，但没有被持续看见。</li>
        <li>会用 AI，但每次写内容都要重新解释背景。</li>
        <li>素材很多，真正写的时候却调用不出来。</li>
      </ul>
      <div class="home-actions" aria-label="快捷入口">
        <a href="/services/">看服务方向</a>
        <a href="/about/">了解关凯迪</a>
      </div>
      <div class="hero-metrics" aria-label="内容系统组成">
        <span>产品梳理</span>
        <span>用户洞察</span>
        <span>选题生产</span>
        <span>改稿学习</span>
      </div>
    </div>
    <figure class="board-figure">
      <div class="board-label">
        <span>Capability Map</span>
        <strong>能力地图</strong>
      </div>
      <img src="/guankaidi-capability-map.svg" alt="关凯迪个人能力地图示意图" />
      <figcaption>围绕个人 IP、AI 写作和内容系统的能力地图。</figcaption>
    </figure>
  </section>

  <section class="signal-grid" aria-labelledby="signals-title">
    <div class="section-heading">
      <p class="eyebrow">Focus</p>
      <h2 id="signals-title">我主要解决什么</h2>
    </div>
    <div class="signal-cards">
      <article>
        <span>01</span>
        <h3>让能力被看见</h3>
        <p>内容不是表演，是把真实交付、判断和方法放到更多人面前，避免能力只停在熟人圈里。</p>
      </article>
      <article>
        <span>02</span>
        <h3>让 AI 懂你的业务</h3>
        <p>先整理产品、用户、语气和写作偏好，再让 AI 写稿，减少通用模板感和反复返工。</p>
      </article>
      <article>
        <span>03</span>
        <h3>让内容流程可复用</h3>
        <p>把素材入口、爆款参考、选题、草稿、改稿学习连成闭环，先手动跑通，再逐步自动化。</p>
      </article>
    </div>
  </section>

  <section class="service-band" aria-labelledby="service-title">
    <div>
      <p class="eyebrow">Work</p>
      <h2 id="service-title">当前业务方向</h2>
      <p>
        以 AI 内容生产系统搭建陪跑为主线，帮助内容创业者、本地商家、小团队负责人，把内容压力变成稳定流程。语音输入后的内容整理器，是正在规划的工具方向。
      </p>
    </div>
    <a href="/services/">查看具体方向</a>
  </section>

  <section class="section-grid" aria-labelledby="latest-title">
    <div class="section-heading">
      <p class="eyebrow">Latest Notes</p>
      <h2 id="latest-title">最新文章</h2>
    </div>
    <PostList posts={latestPosts} />
  </section>

  <section class="topic-strip" aria-labelledby="topics-title">
    <div>
      <p class="eyebrow">Topics</p>
      <h2 id="topics-title">常写主题</h2>
    </div>
    <div class="topic-links">
      {
        tags.map((tag) => (
          <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
        ))
      }
    </div>
  </section>
</BaseLayout>
