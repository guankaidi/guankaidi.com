---
import BaseLayout from "./BaseLayout.astro";
import { formatDate } from "../lib/posts";

const { frontmatter } = Astro.props;
const tags = frontmatter.tags ?? [];
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <article class="article-shell">
    <header class="article-header">
      <a class="back-link" href="/">返回首页</a>
      <p class="post-meta">
        <time datetime={frontmatter.pubDate}>{formatDate(frontmatter.pubDate)}</time>
        {frontmatter.readingTime && <span>{frontmatter.readingTime}</span>}
      </p>
      <h1>{frontmatter.title}</h1>
      <p class="article-description">{frontmatter.description}</p>
      {
        tags.length > 0 && (
          <div class="article-tags" aria-label="文章标签">
            {tags.map((tag: string) => (
              <a href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
